{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "public"
  ],
  "permissions": [
  "core:default",
  "sql:default",
  "sql:allow-execute",
  "sql:allow-select",
  "core:webview:allow-internal-toggle-devtools",
  "dialog:default",
  "fs:default",
  "fs:allow-read-text-file",
  "fs:allow-write-file",
  "core:window:allow-set-fullscreen"
  ]
}